---
import Base from './Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CtaPanel from '../components/CtaPanel.astro';

const siteUrl = 'https://info.m-eitan.co.il';

const { title, description, path, headline, lead, datePublished, dateModified } = Astro.props;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline,
  description,
  inLanguage: 'he',
  url: `${siteUrl}${path}`,
  mainEntityOfPage: `${siteUrl}${path}`,
  image: `${siteUrl}/og-image.png`,
  datePublished,
  dateModified: dateModified ?? datePublished,
  author: { '@id': `${siteUrl}/#organization` },
  publisher: { '@id': `${siteUrl}/#organization` },
};

const crumbs = [
  { name: 'ראשי', href: '/' },
  { name: 'מדריכים', href: '/guides/' },
  { name: headline, href: path },
];
---

<Base title={title} description={description} path={path} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    <slot name="head" />
  </Fragment>

  <Breadcrumbs items={crumbs} />

  <article>
    <header class="article-hero container">
      <h1>{headline}</h1>
      <p class="article-lead">{lead}</p>
    </header>
    <div class="prose container">
      <slot />
    </div>
  </article>

  <CtaPanel />
</Base>
