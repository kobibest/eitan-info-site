---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CtaPanel from '../components/CtaPanel.astro';
import CubeLogo from '../components/CubeLogo.astro';

const title = 'אודות איתן — מערכת CRM ישראלית ליועצי משכנתאות';
const description =
  'איתן היא מערכת CRM ישראלית לניהול עסק של ייעוץ משכנתאות, שנבנתה על ידי יועץ משכנתאות פעיל. הכירו את הסיפור, הגישה והערכים מאחורי המערכת.';

const crumbs = [
  { name: 'ראשי', href: '/' },
  { name: 'אודות', href: '/about/' },
];

const aboutLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'אודות איתן',
  url: 'https://info.m-eitan.co.il/about/',
  inLanguage: 'he',
  mainEntity: { '@id': 'https://info.m-eitan.co.il/#organization' },
};
---

<Base title={title} description={description} path="/about/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(aboutLd)} />
  </Fragment>

  <Breadcrumbs items={crumbs} />

  <article>
    <header class="article-hero container">
      <CubeLogo size={72} class="about-logo" />
      <h1>אודות איתן</h1>
      <p class="article-lead">מערכת ניהול ישראלית ליועצי משכנתאות — שנבנתה מתוך השטח.</p>
    </header>

    <div class="prose container">
      <h2>למה בנינו את איתן</h2>
      <p>
        איתן נולדה מתסכול מוכר לכל יועץ משכנתאות: ניהול העסק התפזר בין גיליונות אקסל, שיחות
        וואטסאפ, תיקיות מייל ומחשבוני ריבית — וכל תיק דרש ז'ונגלינג בלתי פוסק בין כלים שלא
        מדברים זה עם זה. המערכות הכלליות שקיימות בשוק לא הכירו את התהליך הישראלי: את שלבי
        העבודה מול הבנקים, את מסמכי החובה, את ייפויי הכוח ואת התמהילים.
      </p>
      <p>
        אז בנינו מערכת אחת שמרכזת את הכל. <strong>איתן</strong> נבנתה על ידי יועץ משכנתאות
        פעיל, סביב תהליך העבודה האמיתי בישראל — מהשיחה הראשונה עם הלקוח ועד החתימה בבנק —
        והיא ממשיכה להתעדכן מתוך העבודה היומיומית בשטח.
      </p>

      <h2>מה המערכת כוללת</h2>
      <ul>
        <li>ניהול לקוחות ותיקי משכנתא עם סטטוסים, מסמכים והיסטוריה מלאה</li>
        <li>סימולטור משכנתא מבוסס נתוני ריבית עדכניים של בנק ישראל</li>
        <li>חתימה דיגיטלית מרובת צדדים — לקוחות, בני זוג וערבים</li>
        <li>אינטגרציית וואטסאפ עסקית לתקשורת מתועדת עם לקוחות</li>
        <li>ניהול משימות עם תלויות וציר זמן לכל תיק</li>
      </ul>

      <h2>הגישה שלנו</h2>
      <p>
        השם איתן והסלוגן שלנו — <strong>"לחשוב קדימה"</strong> — מסכמים את הגישה: יציבות
        בניהול העסק היום, וראייה קדימה של הצעד הבא בכל תיק. אנחנו מאמינים שכלי עבודה טוב
        צריך להיות פשוט להפעלה (בדפדפן, בלי התקנה), בטוח (המידע נשמר בשרתים מאובטחים באיחוד
        האירופי), ובנוי על המציאות של השוק הישראלי — לא על תרגום של תבנית זרה.
      </p>

      <h2>איפה מוצאים אותנו</h2>
      <p>
        המערכת זמינה בכתובת
        <a href="https://www.m-eitan.co.il">www.m-eitan.co.il</a> — אפשר
        <a href="https://www.m-eitan.co.il/register">לפתוח חשבון</a> ולהתחיל לעבוד עוד היום.
        ליועצים שבודקים את השוק, ריכזנו גם
        <a href="/guides/">מדריכים מעשיים לבחירת מערכת ולניהול העסק</a>.
      </p>
    </div>
  </article>

  <CtaPanel />
</Base>

<style>
  :global(.about-logo) {
    margin-bottom: 18px;
    filter: drop-shadow(0 10px 20px rgba(16, 31, 77, 0.16));
  }
</style>
