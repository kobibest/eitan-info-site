---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CtaPanel from '../components/CtaPanel.astro';
import CubeLogo from '../components/CubeLogo.astro';

const title = 'אודות איתן — מערכת CRM ליועצי משכנתאות';
const description =
  'איתן היא מערכת CRM לניהול עסק של ייעוץ משכנתאות: לקוחות, לידים, תיקים, משימות וסימולטור — בממשק מסודר ופשוט. הכירו את הגישה והערכים מאחורי המערכת.';

const crumbs = [
  { name: 'ראשי', href: '/' },
  { name: 'אודות', href: '/about/' },
];

const aboutLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'אודות איתן',
  url: 'https://info.m-eitan.co.il/about/',
  inLanguage: 'he',
  mainEntity: { '@id': 'https://info.m-eitan.co.il/#organization' },
};
---

<Base title={title} description={description} path="/about/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(aboutLd)} />
  </Fragment>

  <Breadcrumbs items={crumbs} />

  <article>
    <header class="article-hero container">
      <CubeLogo size={72} class="about-logo" />
      <h1>אודות איתן</h1>
      <p class="article-lead">מערכת ניהול ליועצי משכנתאות — שנבנתה סביב עיקרון אחד: סדר.</p>
    </header>

    <div class="prose container">
      <h2>הגישה שלנו</h2>
      <p>
        עסק של ייעוץ משכנתאות מנהל הרבה דברים במקביל: לידים שנכנסים מקמפיינים, תיקים בשלבים
        שונים מול הבנקים, מסמכים, חתימות, משימות ותזכורות. מערכת ניהול אמורה לעשות מהעומס
        הזה סדר — אבל בפועל, מערכות רבות מוסיפות עומס משלהן: מסכים צפופים, אינסוף שדות,
        ותהליכי הטמעה ארוכים.
      </p>
      <p>
        <strong>איתן</strong> נבנתה בדיוק הפוך. כל החלטת עיצוב במערכת נבחנת מול שלוש שאלות:
        האם זה מסודר? האם זה ברור במבט ראשון? האם זה פשוט לתפעול? התוצאה היא מערכת שבה לכל
        תיק יש מסך אחד ברור, כל פעולה נמצאת איפה שמצפים לה, ומתחילים לעבוד בה תוך דקות —
        בלי הדרכות ארוכות ובלי פרויקט הטמעה.
      </p>

      <h2>מה המערכת כוללת</h2>
      <ul>
        <li>ניהול לקוחות ותיקי משכנתא עם סטטוסים, מסמכים והיסטוריה מלאה</li>
        <li>ניהול קמפיינים ולידים — מהקליק הראשון ועד תיק פעיל</li>
        <li>סימולטור משכנתא מקצועי מבוסס נתוני ריבית עדכניים של בנק ישראל</li>
        <li>ניהול משימות עם תלויות וציר זמן, ותזכורות לכל תיק</li>
        <li>חתימה דיגיטלית מרובת צדדים — לקוחות, בני זוג וערבים</li>
      </ul>

      <h2>לחשוב קדימה</h2>
      <p>
        השם איתן והסלוגן שלנו — <strong>"לחשוב קדימה"</strong> — מסכמים את מה שאנחנו מאמינים
        בו: יציבות בניהול העסק היום, וראייה קדימה של הצעד הבא בכל תיק ובכל ליד. כלי עבודה
        טוב צריך להיות פשוט להפעלה (בדפדפן, בלי התקנה), בטוח (המידע נשמר בשרתים מאובטחים
        באיחוד האירופי), ולתת לכם להתמקד בייעוץ — לא בתפעול המערכת.
      </p>

      <h2>איפה מוצאים אותנו</h2>
      <p>
        המערכת זמינה בכתובת
        <a href="https://www.m-eitan.co.il">www.m-eitan.co.il</a> — אפשר
        <a href="https://www.m-eitan.co.il/register">לפתוח חשבון</a> ולהתחיל לעבוד עוד היום.
        ליועצים שבודקים את השוק, ריכזנו גם
        <a href="/guides/">מדריכים מעשיים לבחירת מערכת ולניהול העסק</a>.
      </p>
    </div>
  </article>

  <CtaPanel />
</Base>

<style>
  :global(.about-logo) {
    margin-bottom: 18px;
    filter: drop-shadow(0 10px 20px rgba(16, 31, 77, 0.16));
  }
</style>
