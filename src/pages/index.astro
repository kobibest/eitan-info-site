---
const registerUrl = 'https://www.m-eitan.co.il/register';
const loginUrl = 'https://www.m-eitan.co.il/login';
const siteUrl = 'https://info.m-eitan.co.il/';

const title = 'איתן — מערכת CRM ליועצי משכנתאות';
const description =
  'מערכת CRM ישראלית ליועצי משכנתאות: ניהול לקוחות ותיקים, סימולטור משכנתא, חתימה דיגיטלית ואינטגרציית וואטסאפ — הכל במערכת אחת.';

const features = [
  {
    title: 'ניהול תיקים ולקוחות',
    text: 'כל הלקוחות והתיקים במקום אחד — סטטוסים, מסמכים והיסטוריה מלאה של כל תיק.',
  },
  {
    title: 'סימולטור משכנתא מבוסס נתוני בנק ישראל',
    text: 'בניית תמהילים והשוואת מסלולים על בסיס נתוני ריבית עדכניים של בנק ישראל.',
  },
  {
    title: 'חתימה דיגיטלית מרובת צדדים',
    text: 'החתמת לקוחות, בני זוג וערבים על ייפוי כוח והסכמים — מרחוק ומכל מכשיר.',
  },
  {
    title: 'אינטגרציית WhatsApp עסקית',
    text: 'שליחת עדכונים, תזכורות ומסמכים ללקוחות ישירות מהמערכת, בערוץ שהם באמת קוראים.',
  },
  {
    title: 'ניהול משימות עם תלויות וציר זמן',
    text: 'תכנון שלבי התיק על ציר זמן, עם תלויות בין משימות כדי ששום שלב לא יתפספס.',
  },
  {
    title: 'נבנתה על ידי יועץ משכנתאות פעיל',
    text: 'המערכת עוצבה סביב תהליך העבודה האמיתי מול הבנקים בישראל — לא תבנית גנרית.',
  },
];

const faqs = [
  {
    q: 'למי מיועדת מערכת איתן?',
    a: 'ליועצי משכנתאות מורשים בישראל, עצמאיים וצוותי ייעוץ, לניהול לקוחות ותיקים במקום אחד.',
  },
  {
    q: 'מה כוללת המערכת?',
    a: 'ניהול לקוחות ותיקי משכנתא, ניהול משימות, סימולטור משכנתא מבוסס נתוני בנק ישראל, חתימה דיגיטלית ואינטגרציית וואטסאפ.',
  },
  {
    q: 'איך מתחילים?',
    a: 'נרשמים בכתובת www.m-eitan.co.il/register. המערכת פועלת בדפדפן, ללא התקנה.',
  },
  {
    q: 'איפה נשמר המידע?',
    a: 'בשרתים באיחוד האירופי (פרנקפורט).',
  },
];

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'איתן CRM',
  alternateName: 'EITAN CRM',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  inLanguage: 'he',
  url: siteUrl,
  description,
  audience: {
    '@type': 'Audience',
    audienceType: 'יועצי משכנתאות בישראל',
  },
};

const faqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};
---

<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="איתן CRM" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqPageLd)} />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <div class="brand">
          <span class="brand-mark">איתן</span>
          <span class="brand-sub">CRM ליועצי משכנתאות</span>
        </div>
        <nav class="header-actions">
          <a class="btn btn-outline" href={loginUrl}>כניסה למערכת</a>
          <a class="btn btn-primary" href={registerUrl}>פתיחת חשבון</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container">
          <h1>מערכת CRM ליועצי משכנתאות</h1>
          <p class="hero-sub">
            איתן מרכזת את כל העבודה של יועץ המשכנתאות — לקוחות, תיקים, משימות, סימולציות
            וחתימות — במערכת אחת שנבנתה בישראל, על התהליך הישראלי.
          </p>
          <div class="cta-row">
            <a class="btn btn-primary btn-lg" href={registerUrl}>פתיחת חשבון</a>
            <a class="btn btn-ghost btn-lg" href={loginUrl}>כניסה למערכת</a>
          </div>
        </div>
      </section>

      <section class="features">
        <div class="container">
          <h2>מה יש במערכת</h2>
          <ul class="feature-grid">
            {
              features.map((f) => (
                <li class="feature-card">
                  <h3>{f.title}</h3>
                  <p>{f.text}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="faq">
        <div class="container">
          <h2>שאלות נפוצות</h2>
          <dl class="faq-list">
            {
              faqs.map(({ q, a }) => (
                <div class="faq-item">
                  <dt>{q}</dt>
                  <dd>
                    {q === 'איך מתחילים?' ? (
                      <>
                        נרשמים בכתובת{' '}
                        <a href={registerUrl}>www.m-eitan.co.il/register</a>. המערכת פועלת
                        בדפדפן, ללא התקנה.
                      </>
                    ) : (
                      a
                    )}
                  </dd>
                </div>
              ))
            }
          </dl>
        </div>
      </section>

      <section class="bottom-cta">
        <div class="container">
          <h2>מוכנים להתחיל?</h2>
          <p>המערכת פועלת בדפדפן, ללא התקנה. אפשר להתחיל לעבוד תוך דקות.</p>
          <div class="cta-row">
            <a class="btn btn-primary btn-lg" href={registerUrl}>פתיחת חשבון</a>
            <a class="btn btn-ghost btn-lg" href={loginUrl}>כניסה למערכת</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>איתן — מערכת CRM ליועצי משכנתאות · <a href="https://www.m-eitan.co.il">www.m-eitan.co.il</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --navy-950: #081527;
    --navy-900: #0b1f3a;
    --navy-800: #102a4c;
    --navy-700: #16365f;
    --blue-500: #2e6fd8;
    --blue-400: #4a86e8;
    --ink: #1c2b3f;
    --muted: #51667f;
    --bg: #f5f8fc;
    --card: #ffffff;
    --line: #dbe5f0;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Heebo', system-ui, -apple-system, sans-serif;
    color: var(--ink);
    background: var(--bg);
    line-height: 1.65;
  }

  .container {
    max-width: 1060px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  a {
    color: var(--blue-500);
  }

  /* Buttons */
  .btn {
    display: inline-block;
    border-radius: 8px;
    padding: 10px 22px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease;
    border: 1px solid transparent;
  }

  .btn-lg {
    padding: 14px 32px;
    font-size: 1.1rem;
  }

  .btn-primary {
    background: var(--blue-500);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--blue-400);
  }

  .btn-outline {
    border-color: var(--line);
    color: var(--navy-800);
    background: transparent;
  }

  .btn-outline:hover {
    border-color: var(--blue-500);
    color: var(--blue-500);
  }

  .btn-ghost {
    border-color: rgba(255, 255, 255, 0.45);
    color: #fff;
    background: transparent;
  }

  .btn-ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  /* Header */
  .site-header {
    background: #fff;
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-block: 14px;
    flex-wrap: wrap;
  }

  .brand {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .brand-mark {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--navy-900);
    letter-spacing: -0.02em;
  }

  .brand-sub {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .header-actions {
    display: flex;
    gap: 10px;
  }

  /* Hero */
  .hero {
    background: linear-gradient(160deg, var(--navy-950) 0%, var(--navy-900) 55%, var(--navy-800) 100%);
    color: #fff;
    padding-block: 88px 96px;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.1rem);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: #c6d5ea;
    max-width: 720px;
    margin: 0 auto 36px;
  }

  .cta-row {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Features */
  .features {
    padding-block: 72px;
  }

  h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    color: var(--navy-900);
    margin-bottom: 32px;
    text-align: center;
  }

  .feature-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 20px;
  }

  .feature-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 26px 24px;
  }

  .feature-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy-800);
    margin-bottom: 8px;
  }

  .feature-card p {
    color: var(--muted);
    font-size: 0.97rem;
  }

  /* FAQ */
  .faq {
    padding-block: 24px 72px;
  }

  .faq-list {
    max-width: 760px;
    margin-inline: auto;
    display: grid;
    gap: 16px;
  }

  .faq-item {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 22px 24px;
  }

  .faq-item dt {
    font-weight: 700;
    color: var(--navy-800);
    font-size: 1.05rem;
    margin-bottom: 6px;
  }

  .faq-item dd {
    color: var(--muted);
  }

  /* Bottom CTA */
  .bottom-cta {
    background: linear-gradient(160deg, var(--navy-900) 0%, var(--navy-700) 100%);
    color: #fff;
    text-align: center;
    padding-block: 64px;
  }

  .bottom-cta h2 {
    color: #fff;
    margin-bottom: 12px;
  }

  .bottom-cta p {
    color: #c6d5ea;
    margin-bottom: 28px;
  }

  /* Footer */
  .site-footer {
    background: var(--navy-950);
    color: #8fa3bd;
    text-align: center;
    padding-block: 22px;
    font-size: 0.9rem;
  }

  .site-footer a {
    color: #b9cbe3;
  }

  @media (max-width: 560px) {
    .hero {
      padding-block: 60px 68px;
    }

    .header-actions {
      width: 100%;
      justify-content: center;
    }
  }
</style>
