---
import CubeLogo from '../components/CubeLogo.astro';

const registerUrl = 'https://www.m-eitan.co.il/register';
const loginUrl = 'https://www.m-eitan.co.il/login';
const siteUrl = 'https://info.m-eitan.co.il/';

const title = 'איתן — מערכת CRM ליועצי משכנתאות';
const description =
  'מערכת CRM ישראלית ליועצי משכנתאות: ניהול לקוחות ותיקים, סימולטור משכנתא, חתימה דיגיטלית ואינטגרציית וואטסאפ — הכל במערכת אחת.';

const features = [
  {
    title: 'ניהול תיקים ולקוחות',
    text: 'כל הלקוחות והתיקים במקום אחד — סטטוסים, מסמכים והיסטוריה מלאה של כל תיק.',
    icon: 'M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z',
  },
  {
    title: 'סימולטור משכנתא מבוסס נתוני בנק ישראל',
    text: 'בניית תמהילים והשוואת מסלולים על בסיס נתוני ריבית עדכניים של בנק ישראל.',
    icon: 'M4 20h16 M7 20v-6 M12 20V9 M17 20V4',
  },
  {
    title: 'חתימה דיגיטלית מרובת צדדים',
    text: 'החתמת לקוחות, בני זוג וערבים על ייפוי כוח והסכמים — מרחוק ומכל מכשיר.',
    icon: 'M17 3a2.83 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z',
  },
  {
    title: 'אינטגרציית WhatsApp עסקית',
    text: 'שליחת עדכונים, תזכורות ומסמכים ללקוחות ישירות מהמערכת, בערוץ שהם באמת קוראים.',
    icon: 'M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z',
  },
  {
    title: 'ניהול משימות עם תלויות וציר זמן',
    text: 'תכנון שלבי התיק על ציר זמן, עם תלויות בין משימות כדי ששום שלב לא יתפספס.',
    icon: 'M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
  },
  {
    title: 'נבנתה על ידי יועץ משכנתאות פעיל',
    text: 'המערכת עוצבה סביב תהליך העבודה האמיתי מול הבנקים בישראל — לא תבנית גנרית.',
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
];

const trustChips = [
  'עובד בדפדפן — ללא התקנה',
  'נתוני ריבית עדכניים של בנק ישראל',
  'המידע נשמר בשרתים באיחוד האירופי',
];

const faqs = [
  {
    q: 'למי מיועדת מערכת איתן?',
    a: 'ליועצי משכנתאות מורשים בישראל, עצמאיים וצוותי ייעוץ, לניהול לקוחות ותיקים במקום אחד.',
  },
  {
    q: 'מה כוללת המערכת?',
    a: 'ניהול לקוחות ותיקי משכנתא, ניהול משימות, סימולטור משכנתא מבוסס נתוני בנק ישראל, חתימה דיגיטלית ואינטגרציית וואטסאפ.',
  },
  {
    q: 'איך מתחילים?',
    a: 'נרשמים בכתובת www.m-eitan.co.il/register. המערכת פועלת בדפדפן, ללא התקנה.',
  },
  {
    q: 'איפה נשמר המידע?',
    a: 'בשרתים באיחוד האירופי (פרנקפורט).',
  },
];

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'איתן CRM',
  alternateName: 'EITAN CRM',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  inLanguage: 'he',
  url: siteUrl,
  description,
  audience: {
    '@type': 'Audience',
    audienceType: 'יועצי משכנתאות בישראל',
  },
};

const faqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};
---

<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />
    <meta name="theme-color" content="#1E3A8A" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="איתן CRM" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}og-image.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqPageLd)} />
  </head>

  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="איתן — דף הבית">
          <CubeLogo size={38} />
          <span class="brand-text">
            <span class="brand-mark">איתן</span>
            <span class="brand-sub">CRM ליועצי משכנתאות</span>
          </span>
        </a>
        <nav class="header-nav" aria-label="ניווט ראשי">
          <a href="#features">מה יש במערכת</a>
          <a href="#faq">שאלות נפוצות</a>
        </nav>
        <div class="header-actions">
          <a class="btn btn-outline" href={loginUrl}>כניסה למערכת</a>
          <a class="btn btn-primary" href={registerUrl}>פתיחת חשבון</a>
        </div>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-bg" aria-hidden="true"></div>
        <div class="container hero-inner">
          <CubeLogo size={84} class="hero-logo" />
          <p class="hero-badge">נבנתה על ידי יועץ משכנתאות פעיל</p>
          <h1>מערכת CRM <span class="hl">ליועצי משכנתאות</span></h1>
          <p class="hero-sub">
            איתן מרכזת את כל העבודה של יועץ המשכנתאות — לקוחות, תיקים, משימות, סימולציות
            וחתימות — במערכת אחת שנבנתה בישראל, על התהליך הישראלי.
          </p>
          <div class="cta-row">
            <a class="btn btn-accent btn-lg" href={registerUrl}>פתיחת חשבון</a>
            <a class="btn btn-outline btn-lg" href={loginUrl}>כניסה למערכת</a>
          </div>
          <ul class="trust-chips">
            {
              trustChips.map((chip) => (
                <li>
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      d="M20 6L9 17l-5-5"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {chip}
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="features" id="features">
        <div class="container">
          <p class="kicker">היכולות של איתן</p>
          <h2>מה יש במערכת</h2>
          <p class="section-sub">כל מה שיועץ משכנתאות צריך כדי לנהל את העסק — במקום אחד.</p>
          <ul class="feature-grid">
            {
              features.map((f) => (
                <li class="feature-card">
                  <span class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                      <path
                        d={f.icon}
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                  <h3>{f.title}</h3>
                  <p>{f.text}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="faq" id="faq">
        <div class="container">
          <p class="kicker">שאלות ותשובות</p>
          <h2>שאלות נפוצות</h2>
          <div class="faq-list">
            {
              faqs.map(({ q, a }, i) => (
                <details class="faq-item" open={i === 0}>
                  <summary>
                    <span>{q}</span>
                    <svg class="chev" viewBox="0 0 24 24" aria-hidden="true">
                      <path
                        d="M6 9l6 6 6-6"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </summary>
                  <p class="faq-answer">
                    {q === 'איך מתחילים?' ? (
                      <>
                        נרשמים בכתובת{' '}
                        <a href={registerUrl}>www.m-eitan.co.il/register</a>. המערכת פועלת
                        בדפדפן, ללא התקנה.
                      </>
                    ) : (
                      a
                    )}
                  </p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      <section class="bottom-cta">
        <div class="container">
          <div class="cta-panel">
            <CubeLogo size={340} class="cta-watermark" />
            <h2>מוכנים להתחיל?</h2>
            <p>המערכת פועלת בדפדפן, ללא התקנה. אפשר להתחיל לעבוד תוך דקות.</p>
            <div class="cta-row">
              <a class="btn btn-accent btn-lg" href={registerUrl}>פתיחת חשבון</a>
              <a class="btn btn-ghost btn-lg" href={loginUrl}>כניסה למערכת</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <CubeLogo size={32} />
          <span>איתן <span class="footer-tagline">— לחשוב קדימה</span></span>
        </div>
        <nav class="footer-links" aria-label="קישורים">
          <a href={registerUrl}>פתיחת חשבון</a>
          <a href={loginUrl}>כניסה למערכת</a>
          <a href="https://www.m-eitan.co.il">www.m-eitan.co.il</a>
        </nav>
        <p class="footer-copy">© {new Date().getFullYear()} איתן — מערכת CRM ליועצי משכנתאות</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --navy: #1e3a8a;
    --navy-dark: #172b66;
    --navy-deep: #101f4d;
    --amber: #f0a31d;
    --amber-dark: #d98e0b;
    --amber-soft: #fdf3df;
    --ink: #1b2540;
    --muted: #56658a;
    --bg: #f7f9fd;
    --card: #ffffff;
    --line: #e2e8f5;
    --ring: rgba(240, 163, 29, 0.55);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Heebo', system-ui, -apple-system, sans-serif;
    color: var(--ink);
    background: var(--bg);
    line-height: 1.65;
  }

  .container {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  a {
    color: var(--navy);
  }

  :focus-visible {
    outline: 3px solid var(--ring);
    outline-offset: 2px;
    border-radius: 6px;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    border-radius: 10px;
    padding: 10px 22px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease, color 0.15s ease,
      box-shadow 0.15s ease;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .btn-lg {
    padding: 14px 34px;
    font-size: 1.1rem;
    border-radius: 12px;
  }

  .btn-primary {
    background: var(--navy);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--navy-dark);
  }

  .btn-accent {
    background: var(--amber);
    color: var(--navy-deep);
    font-weight: 700;
    box-shadow: 0 8px 20px -8px rgba(240, 163, 29, 0.65);
  }

  .btn-accent:hover {
    background: var(--amber-dark);
    box-shadow: 0 10px 22px -8px rgba(217, 142, 11, 0.7);
  }

  .btn-outline {
    border-color: #cbd6ec;
    color: var(--navy);
    background: #fff;
  }

  .btn-outline:hover {
    border-color: var(--navy);
  }

  .btn-ghost {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
    background: transparent;
  }

  .btn-ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-block: 12px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .brand-mark {
    font-size: 1.45rem;
    font-weight: 900;
    color: var(--navy);
    letter-spacing: -0.02em;
  }

  .brand-sub {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 500;
  }

  .header-nav {
    display: flex;
    gap: 26px;
    margin-inline-start: auto;
  }

  .header-nav a {
    text-decoration: none;
    color: var(--ink);
    font-weight: 500;
    font-size: 0.98rem;
  }

  .header-nav a:hover {
    color: var(--navy);
  }

  .header-actions {
    display: flex;
    gap: 10px;
  }

  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding-block: 84px 92px;
    background: linear-gradient(180deg, #ffffff 0%, #f2f6fd 60%, var(--bg) 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(600px 300px at 15% 0%, rgba(30, 58, 138, 0.08), transparent 70%),
      radial-gradient(600px 320px at 85% 10%, rgba(240, 163, 29, 0.12), transparent 70%);
  }

  .hero-inner {
    position: relative;
    animation: rise 0.7s ease-out both;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-inner {
      animation: none;
    }
  }

  .hero-logo {
    margin-bottom: 22px;
    filter: drop-shadow(0 14px 24px rgba(16, 31, 77, 0.18));
  }

  .hero-badge {
    display: inline-block;
    background: var(--amber-soft);
    color: #8a5b06;
    border: 1px solid #f3ddab;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 999px;
    padding: 6px 16px;
    margin-bottom: 22px;
  }

  .hero h1 {
    font-size: clamp(2.1rem, 5.2vw, 3.4rem);
    font-weight: 900;
    line-height: 1.2;
    color: var(--navy-deep);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .hero h1 .hl {
    background-image: linear-gradient(transparent 64%, rgba(240, 163, 29, 0.38) 64%);
  }

  .hero-sub {
    font-size: clamp(1.05rem, 2.2vw, 1.28rem);
    color: var(--muted);
    max-width: 700px;
    margin: 0 auto 36px;
  }

  .cta-row {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .trust-chips {
    list-style: none;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px 26px;
    margin-top: 38px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .trust-chips li {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .trust-chips svg {
    width: 16px;
    height: 16px;
    color: var(--amber-dark);
    flex-shrink: 0;
  }

  /* Sections */
  section h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.15rem);
    font-weight: 800;
    color: var(--navy-deep);
    text-align: center;
    margin-bottom: 12px;
  }

  .kicker {
    text-align: center;
    color: var(--amber-dark);
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }

  .section-sub {
    text-align: center;
    color: var(--muted);
    max-width: 620px;
    margin: 0 auto 40px;
    font-size: 1.05rem;
  }

  /* Features */
  .features {
    padding-block: 84px;
  }

  .feature-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }

  .feature-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 28px 26px;
    box-shadow: 0 1px 2px rgba(16, 31, 77, 0.04);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .feature-card:hover {
    border-color: #f1cd8b;
    box-shadow: 0 14px 30px -14px rgba(16, 31, 77, 0.18);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(145deg, #eef3fc, #e3ebf9);
    color: var(--navy);
    margin-bottom: 18px;
  }

  .feature-icon svg {
    width: 24px;
    height: 24px;
  }

  .feature-card h3 {
    font-size: 1.12rem;
    font-weight: 700;
    color: var(--navy-dark);
    margin-bottom: 8px;
  }

  .feature-card p {
    color: var(--muted);
    font-size: 0.97rem;
  }

  /* FAQ */
  .faq {
    padding-block: 8px 84px;
  }

  .faq .kicker + h2 {
    margin-bottom: 32px;
  }

  .faq-list {
    max-width: 760px;
    margin-inline: auto;
    display: grid;
    gap: 14px;
  }

  .faq-item {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
    font-weight: 700;
    color: var(--navy-dark);
    font-size: 1.05rem;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item .chev {
    width: 20px;
    height: 20px;
    color: var(--amber-dark);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .chev {
    transform: rotate(180deg);
