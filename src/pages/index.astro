---
import Base from '../layouts/Base.astro';
import CubeLogo from '../components/CubeLogo.astro';
import CtaPanel from '../components/CtaPanel.astro';

const registerUrl = 'https://www.m-eitan.co.il/register';
const loginUrl = 'https://www.m-eitan.co.il/login';
const siteUrl = 'https://info.m-eitan.co.il/';

const title = 'מערכת CRM ליועצי משכנתאות — איתן | ניהול לקוחות, לידים וסימולטור משכנתא';
const description =
  'איתן — מערכת CRM ליועצי משכנתאות: ניהול לקוחות ותיקים, ניהול קמפיינים ולידים, סימולטור משכנתא מקצועי מבוסס נתוני בנק ישראל, משימות, תזכורות וחתימה דיגיטלית. ממשק מסודר ופשוט לתפעול, עובד בדפדפן ללא התקנה.';

const features = [
  {
    title: 'ניהול תיקים ולקוחות',
    text: 'כל הלקוחות והתיקים במקום אחד — סטטוסים, מסמכים והיסטוריה מלאה של כל תיק.',
    icon: 'M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z',
  },
  {
    title: 'ניהול קמפיינים ולידים',
    text: 'קליטת לידים מכל מקור, מעקב אחרי הקמפיינים שמביאים אותם, והמרה מסודרת מליד לתיק.',
    icon: 'M3 4h18l-7 8.5V19l-4 2v-8.5L3 4z',
  },
  {
    title: 'סימולטור משכנתא מקצועי',
    text: 'בניית תמהילים והשוואת מסלולים על בסיס נתוני ריבית עדכניים של בנק ישראל.',
    icon: 'M4 20h16 M7 20v-6 M12 20V9 M17 20V4',
  },
  {
    title: 'חתימה דיגיטלית מרובת צדדים',
    text: 'החתמת לקוחות, בני זוג וערבים על ייפוי כוח והסכמים — מרחוק ומכל מכשיר.',
    icon: 'M17 3a2.83 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z',
  },
  {
    title: 'ניהול משימות ותזכורות',
    text: 'משימות עם תלויות וציר זמן לכל תיק, ותזכורות שדואגות ששום שלב ושום לקוח לא יתפספסו.',
    icon: 'M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
  },
  {
    title: 'סדר ובהירות מהרגע הראשון',
    text: 'מסך אחד ברור לכל תיק ותמונת מצב מלאה של העסק — בלי מסכים עמוסים ובלי הגדרות אינסופיות.',
    icon: 'M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5z M3 10h18 M10 21V10',
  },
];

const trustChips = [
  'עובד בדפדפן — ללא התקנה',
  'נתוני ריבית עדכניים של בנק ישראל',
  'המידע נשמר בשרתים באיחוד האירופי',
];

const guides = [
  {
    href: '/guides/choosing-mortgage-crm/',
    title: 'איך בוחרים מערכת CRM ליועצי משכנתאות?',
    text: 'המדריך המלא: היכולות שחייבות להיות במערכת, שאלות לספק וטעויות נפוצות בבחירה.',
  },
  {
    href: '/guides/excel-vs-crm/',
    title: 'אקסל מול מערכת ייעודית לניהול תיקי משכנתא',
    text: 'מתי אקסל מפסיק להספיק, מה ההבדל בפועל, ואיך עוברים בלי לאבד מידע.',
  },
  {
    href: '/guides/mortgage-simulator/',
    title: 'סימולטור משכנתא ליועצים — למה נתוני בנק ישראל חשובים',
    text: 'איך סימולטור מבוסס נתונים עדכניים משדרג את בניית התמהיל ואת האמון של הלקוח.',
  },
];

const faqs = [
  {
    q: 'מה זו מערכת CRM ליועצי משכנתאות?',
    a: 'מערכת ניהול ייעודית לעסק של יועץ משכנתאות: ניהול לקוחות ותיקים, קליטת לידים ומעקב קמפיינים, שלבי התהליך מול הבנקים, מסמכים, משימות ותזכורות, וכלי עבודה כמו סימולטור משכנתא וחתימה דיגיטלית — הכל במקום אחד.',
  },
  {
    q: 'למי מיועדת מערכת איתן?',
    a: 'ליועצי משכנתאות מורשים, עצמאיים וצוותי ייעוץ, לניהול לקוחות ותיקים במקום אחד.',
  },
  {
    q: 'מה כוללת המערכת?',
    a: 'ניהול לקוחות ותיקי משכנתא, ניהול קמפיינים ולידים, סימולטור משכנתא מקצועי מבוסס נתוני בנק ישראל, ניהול משימות ותזכורות, וחתימה דיגיטלית מרובת צדדים.',
  },
  {
    q: 'במה איתן שונה ממערכות ניהול אחרות?',
    a: 'בסדר ובפשטות. איתן שמה את הדגש על בהירות ויזואלית ופשטות תפעולית: מסך אחד ברור לכל תיק, מינימום קליקים לכל פעולה, ועקומת למידה של דקות — בלי הדרכות ארוכות ובלי מסכים עמוסים.',
  },
  {
    q: 'האם המערכת מתאימה גם ליועץ משכנתאות עצמאי?',
    a: 'כן. איתן מתאימה גם ליועץ עצמאי שמנהל את כל התיקים לבד וגם לצוות ייעוץ שעובד יחד על אותם לקוחות.',
  },
  {
    q: 'איך מתחילים?',
    a: 'נרשמים בכתובת www.m-eitan.co.il/register. המערכת פועלת בדפדפן, ללא התקנה.',
  },
  {
    q: 'איפה נשמר המידע?',
    a: 'בשרתים באיחוד האירופי (פרנקפורט).',
  },
];

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'איתן CRM',
  alternateName: 'EITAN CRM',
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'CRM ליועצי משכנתאות',
  operatingSystem: 'Web',
  inLanguage: 'he',
  url: siteUrl,
  description,
  featureList: features.map((f) => f.title),
  audience: {
    '@type': 'Audience',
    audienceType: 'יועצי משכנתאות בישראל',
  },
  publisher: { '@id': 'https://info.m-eitan.co.il/#organization' },
};

const faqPageLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};
---

<Base title={title} description={description} path="/">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqPageLd)} />
  </Fragment>

  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <CubeLogo size={84} class="hero-logo" />
      <p class="hero-badge">לחשוב קדימה</p>
      <h1>מערכת CRM <span class="hl">ליועצי משכנתאות</span></h1>
      <p class="hero-sub">
        איתן מרכזת את כל העבודה של יועץ המשכנתאות — לקוחות, לידים, תיקים, משימות
        וסימולציות — במערכת אחת מסודרת, עם ממשק נקי ופשוט שנותן תמונת מצב מלאה בכל רגע.
      </p>
      <div class="cta-row">
        <a class="btn btn-accent btn-lg" href={registerUrl}>פתיחת חשבון</a>
        <a class="btn btn-outline btn-lg" href={loginUrl}>כניסה למערכת</a>
      </div>
      <ul class="trust-chips">
        {
          trustChips.map((chip) => (
            <li>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M20 6L9 17l-5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              {chip}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="features" id="features">
    <div class="container">
      <p class="kicker">היכולות של איתן</p>
      <h2>מה יש במערכת</h2>
      <p class="section-sub">כל מה שיועץ משכנתאות צריך כדי לנהל את העסק — במקום אחד.</p>
      <ul class="card-grid">
        {
          features.map((f) => (
            <li class="card feature-card">
              <span class="feature-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path
                    d={f.icon}
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <h3>{f.title}</h3>
              <p>{f.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="why" id="why">
    <div class="container why-inner">
      <p class="kicker">למה איתן</p>
      <h2>מערכת ניהול שעושה סדר — לא מוסיפה עומס</h2>
      <div class="why-text">
        <p>
          <strong>מערכת CRM ליועצי משכנתאות</strong> אמורה לפשט את היום — אבל מערכות ניהול
          רבות עמוסות במסכים, שדות והגדרות, עד שהתפעול שלהן הופך בעצמו לעבודה. איתן נבנתה
          בדיוק הפוך: ממשק נקי ומסודר, שבו לכל תיק יש מסך אחד ברור, כל פעולה נמצאת איפה
          שמצפים לה, ותוך רגע רואים מה הסטטוס של כל לקוח ומה הצעד הבא.
        </p>
        <p>
          זו <strong>תוכנה לניהול תיקי משכנתא</strong> שמלווה את כל שלבי העבודה מול הבנקים:
          מקליטת הליד והקמפיין שהביא אותו, דרך איסוף מסמכים וייפוי כוח בחתימה דיגיטלית,
          בניית תמהיל ב<a href="/guides/mortgage-simulator/">סימולטור משכנתא מבוסס נתוני בנק ישראל</a>,
          ועד אישור סופי וליווי אחרי לקיחת המשכנתא — הכל במקום אחד, בלי לקפוץ בין כלים.
        </p>
        <p>
          מחפשים <strong>מערכת ליועצי משכנתאות</strong> ולא בטוחים מה לבדוק? המדריך שלנו על
          <a href="/guides/choosing-mortgage-crm/">איך בוחרים מערכת CRM ליועץ משכנתאות</a>
          מרכז את היכולות החשובות, שאלות שכדאי לשאול כל ספק, וטעויות נפוצות בבחירה.
        </p>
      </div>
    </div>
  </section>

  <section class="guides-teaser">
    <div class="container">
      <p class="kicker">מדריכים ליועצי משכנתאות</p>
      <h2>כדאי לקרוא לפני שבוחרים מערכת</h2>
      <ul class="card-grid guides-grid">
        {
          guides.map((g) => (
            <li class="card guide-card">
              <a href={g.href}>
                <h3>{g.title}</h3>
                <p>{g.text}</p>
                <span class="read-more">לקריאת המדריך ←</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="faq" id="faq">
    <div class="container">
      <p class="kicker">שאלות ותשובות</p>
      <h2>שאלות נפוצות</h2>
      <div class="faq-list">
        {
          faqs.map(({ q, a }, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>
                <span>{q}</span>
                <svg class="chev" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    d="M6 9l6 6 6-6"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </summary>
              <p class="faq-answer">
                {q === 'איך מתחילים?' ? (
                  <>
                    נרשמים בכתובת{' '}
                    <a href={registerUrl}>www.m-eitan.co.il/register</a>. המערכת פועלת
                    בדפדפן, ללא התקנה.
                  </>
                ) : (
                  a
                )}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CtaPanel />
</Base>

<style>
  /* Hero */
  .hero {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding-block: 84px 92px;
    background: linear-gradient(180deg, #ffffff 0%, #f2f6fd 60%, var(--bg) 100%);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(600px 300px at 15% 0%, rgba(30, 58, 138, 0.08), transparent 70%),
      radial-gradient(600px 320px at 85% 10%, rgba(240, 163, 29, 0.12), transparent 70%);
  }

  .hero-inner {
    position: relative;
    animation: rise 0.7s ease-out both;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-inner {
      animation: none;
    }
  }

  :global(.hero-logo) {
    margin-bottom: 22px;
    filter: drop-shadow(0 14px 24px rgba(16, 31, 77, 0.18));
  }

  .hero-badge {
    display: inline-block;
    background: var(--amber-soft);
    color: #8a5b06;
    border: 1px solid #f3ddab;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 999px;
    padding: 6px 16px;
    margin-bottom: 22px;
  }

  .hero h1 {
    font-size: clamp(2.1rem, 5.2vw, 3.4rem);
    font-weight: 900;
    line-height: 1.2;
    color: var(--navy-deep);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .hero h1 .hl {
    background-image: linear-gradient(transparent 64%, rgba(240, 163, 29, 0.38) 64%);
  }

  .hero-sub {
    font-size: clamp(1.05rem, 2.2vw, 1.28rem);
    color: var(--muted);
    max-width: 700px;
    margin: 0 auto 36px;
  }

  .trust-chips {
    list-style: none;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px 26px;
    margin-top: 38px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .trust-chips li {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  .trust-chips svg {
    width: 16px;
    height: 16px;
    color: var(--amber-dark);
    flex-shrink: 0;
  }

  /* Features */
  .features {
    padding-block: 84px 40px;
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(145deg, #eef3fc, #e3ebf9);
    color: var(--navy);
    margin-bottom: 18px;
  }

  .feature-icon svg {
    width: 24px;
    height: 24px;
  }

  .feature-card h3 {
    font-size: 1.12rem;
    font-weight: 700;
    color: var(--navy-dark);
    margin-bottom: 8px;
  }

  .feature-card p {
    color: var(--muted);
    font-size: 0.97rem;
  }

  /* Why (SEO content) */
  .why {
    padding-block: 44px 40px;
  }

  .why-text {
    max-width: 760px;
    margin-inline: auto;
    font-size: 1.05rem;
  }

  .why-text p {
    margin-bottom: 16px;
  }

  .why-text strong {
    color: var(--navy-dark);
  }

  /* Guides teaser */
  .guides-teaser {
    padding-block: 44px 40px;
  }

  .guides-grid {
    margin-top: 28px;
  }

  .guide-card {
    padding: 0;
  }

  .guide-card a {
    display: block;
    padding: 28px 26px;
    text-decoration: none;
    height: 100%;
  }

  .guide-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy-dark);
    margin-bottom: 8px;
  }

  .guide-card p {
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 14px;
  }

  .read-more {
    color: var(--amber-dark);
    font-weight: 700;
    font-size: 0.92rem;
  }

  /* FAQ */
  .faq {
    padding-block: 44px 84px;
  }

  .faq h2 {
    margin-bottom: 32px;
  }

  .faq-list {
    max-width: 760px;
    margin-inline: auto;
    display: grid;
    gap: 14px;
  }

  .faq-item {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
  }

  .faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 22px;
    font-weight: 700;
    color: var(--navy-dark);
    font-size: 1.05rem;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item .chev {
    width: 20px;
    height: 20px;
    color: var(--amber-dark);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .chev {
    transform: rotate(180deg);
  }

  .faq-item[open] summary {
    border-bottom: 1px solid var(--line);
  }

  .faq-answer {
    padding: 16px 22px 20px;
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .hero {
      padding-block: 56px 64px;
    }
  }
</style>
